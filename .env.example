# ===== surf-agent configuration =====
# Copy this file to `.env` and fill in the values for whichever backend(s) you use.

# --- Default backend ---
# One of: anthropic | openai | ollama
SURF_AGENT_PROVIDER=anthropic

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Optional model override. Default: claude-opus-4-7
# SURF_AGENT_MODEL=claude-opus-4-7

# --- OpenAI ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=            # optional (for Azure / local compatible endpoints)

# --- Ollama (local) ---
# OLLAMA_HOST=http://localhost:11434
# SURF_AGENT_MODEL=qwen2.5:7b

# --- Browser ---
# SURF_AGENT_HEADLESS=false     # true = headless, false = show browser window
# SURF_AGENT_BROWSER=chromium   # chromium | firefox | webkit
# SURF_AGENT_MAX_STEPS=25       # safety cap on agent-loop iterations
